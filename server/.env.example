# ===== Server =====
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ===== MySQL Database =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=task_management_system

# ===== Auth =====
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=8h
# Session inactivity in minutes (SRS 5.2: sessions expire after 30 min)
SESSION_IDLE_MINUTES=30

# ===== File uploads =====
UPLOAD_DIR=uploads
# Max size per file in MB (1024 = 1 GB) and max files per submission
MAX_UPLOAD_MB=1024
MAX_UPLOAD_FILES=10

# ===== ML / Analytics engine =====
# Engagement risk threshold (SRS default 40)
ENGAGEMENT_RISK_THRESHOLD=40
# Cron schedule for the nightly engagement/performance recalculation
SCORING_CRON=0 2 * * *
# Max peer reviewers automatically assigned per uploaded task report (1-3)
PEER_REVIEWERS_PER_SUBMISSION=3

# ===== Email (optional). If left blank, emails are logged to the console) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Task Management System <no-reply@tms.local>

# ===== Demo seed admin =====
SEED_ADMIN_EMAIL=admin@tms.local
SEED_ADMIN_PASSWORD=Admin@123
